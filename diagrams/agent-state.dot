digraph G {
  rankdir="LR";
  bgcolor="transparent";
  node [fontname="Helvetica", fontsize=14, shape=box, style="filled,rounded", fillcolor="#1a1e27", color="#8892b0", fontcolor="#ffffff", penwidth=2];
  edge [fontname="Helvetica", fontsize=11, color="#7b8296", fontcolor="#cfd6e4", penwidth=1.4, arrowsize=0.8];
  graph [fontname="Helvetica", fontsize=12, fontcolor="#cfd6e4", style="rounded", bgcolor="transparent", color="#3a4055"];
  compound=true;
  "stateDiagram-v2" [label="stateDiagram-v2", shape=box, style="filled,rounded" fillcolor="#1a1e27" color="#8892b0" fontcolor="#ffffff" penwidth=2];
  "Planning" [label="Planning", shape=box, style="filled,rounded" fillcolor="#1a1e27" color="#8892b0" fontcolor="#ffffff" penwidth=2];
  "Acting" [label="Acting", shape=box, style="filled,rounded" fillcolor="#1a1e27" color="#8892b0" fontcolor="#ffffff" penwidth=2];
  "Reviewing" [label="Reviewing", shape=box, style="filled,rounded" fillcolor="#1a1e27" color="#8892b0" fontcolor="#ffffff" penwidth=2];
  "Finalizing" [label="Finalizing", shape=box, style="filled,rounded" fillcolor="#1a1e27" color="#8892b0" fontcolor="#ffffff" penwidth=2];
  "Failed" [label="Failed", shape=box, style="filled,rounded" fillcolor="#1a1e27" color="#8892b0" fontcolor="#ffffff" penwidth=2];
  "[*]" -> "Planning" [style="solid"];
  "Planning" -> "Acting" [style="solid"];
  "Acting" -> "Reviewing" [style="solid"];
  "Reviewing" -> "Planning" [style="solid"];
  "Reviewing" -> "Finalizing" [style="solid"];
  "Acting" -> "Failed" [style="solid"];
  "Failed" -> "Planning" [style="solid"];
  "Failed" -> "[*] : retries_exhausted" [style="solid"];
  "Finalizing" -> "[*]" [style="solid"];
}